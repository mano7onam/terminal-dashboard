build/
# Explicit patterns if someone builds next to the repo root
*.dmg
*.app/
!assets/  # keep source assets
# Intermediate icon / dmg tooling
*.iconset/
*.icns
# Optional: allow publishing a release asset path via CI only
# (never commit large DMGs to git history)
dmg-stage/
_rw.dmg
*.sparseimage

# Swift / Xcode leftovers
.swiftpm/
.build/
DerivedData/
*.xcodeproj/
*.xcworkspace/
xcuserdata/

